{
  "name": "safe-travels-api",
  "version": "0.1.0",
  "description": "Repositório destinado ao registro da elaboração do Trabalho de Conclusão de Curso (TCC) de Sistemas de Informação do aluno Vicente Hofmeister pela Pontifícia Universidade Católica do Rio Grande do Sul (PUCRS).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "docker:build": "docker build -t safe-travels-api:dev .",
    "docker:up": "docker compose up -d --force-recreate",
    "docker:reset": "docker compose down -v --remove-orphans && docker compose up -d --build",
    "docker:down": "docker compose down --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "docker:api:up": "docker compose up -d --force-recreate api",
    "docker:api:down": "docker compose stop api",
    "docker:api:logs": "docker compose logs -f api",
    "docker:db:up": "docker compose up -d database",
    "docker:db:down": "docker compose stop database",
    "docker:db:logs": "docker compose logs -f database",
    "docker:seed": "docker compose --profile seed run --rm --build seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vicente-hofmeister/Safe-Travels-API.git"
  },
  "keywords": [],
  "author": "vicente-hofmeister",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/vicente-hofmeister/Safe-Travels-API/issues"
  },
  "homepage": "https://github.com/vicente-hofmeister/Safe-Travels-API#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  }
}

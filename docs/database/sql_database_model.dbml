// Safe Travels — Database Model (plano final)
// Última atualização: 2026-04-26
// Ferramenta de visualização: https://dbdiagram.io

Table users {
  user_id varchar [pk, default: `gen_random_uuid()`]
  username varchar(80) [not null, unique]
  name varchar(150) [not null]
  email varchar(255) [not null, unique]
  phone varchar
  password_hash text [not null]
  profile_image varchar
  privacy_settings varchar [not null, default: "default", note: "default | private | followers-only"]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    username
    email
  }
}

Table follows {
  follower_id varchar [not null, ref: > users.user_id]
  following_id varchar [not null, ref: > users.user_id]
  tier varchar [not null, default: "regular", note: "regular | close | trusted"]
  followed_at timestamptz [not null, default: `now()`]

  indexes {
    (follower_id, following_id) [pk]
    following_id
  }
}

Table groups {
  group_id varchar(120) [pk, default: `gen_random_uuid()`]
  owner_id varchar(120) [not null, ref: > users.user_id]
  name varchar(150) [not null]
  description varchar(500)
  profile_image varchar
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table group_members {
  group_id varchar(120) [not null, ref: > groups.group_id]
  user_id varchar(120) [not null, ref: > users.user_id]
  joined_at timestamptz [not null, default: `now()`]

  indexes {
    (group_id, user_id) [pk]
    user_id
  }
}

Table trips {
  trip_id varchar(120) [pk, default: `gen_random_uuid()`]
  title varchar(150) [not null]
  description text
  trip_image varchar
  start_date date [not null]
  end_date date
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table user_trips {
  user_id varchar(120) [not null, ref: > users.user_id]
  trip_id varchar(120) [not null, ref: > trips.trip_id]
  joined_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, trip_id) [pk]
    trip_id
  }
}

Table group_trips {
  group_id varchar(120) [not null, ref: > groups.group_id]
  trip_id varchar(120) [not null, ref: > trips.trip_id]
  joined_at timestamptz [not null, default: `now()`]

  indexes {
    (group_id, trip_id) [pk]
    trip_id
  }
}

// Localização é sempre ancorada no usuário.
// Vínculos com grupos e viagens são feitos via tabelas de junção,
// permitindo que um evento seja compartilhado com múltiplos contextos
// sem duplicação de dados.
Table location_events {
  location_event_id bigserial [pk]
  user_id varchar(120) [not null, ref: > users.user_id]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  accuracy_meters int
  captured_at timestamptz [not null, default: `now()`, note: "Horário do dispositivo"]
  created_at timestamptz [not null, default: `now()`, note: "Horário de recepção pelo servidor"]

  indexes {
    (user_id, captured_at)
  }
}

Table location_event_groups {
  location_event_id bigint [not null, ref: > location_events.location_event_id]
  group_id varchar(120) [not null, ref: > groups.group_id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (location_event_id, group_id) [pk]
    (group_id, location_event_id)
  }
}

Table location_event_trips {
  location_event_id bigint [not null, ref: > location_events.location_event_id]
  trip_id varchar(120) [not null, ref: > trips.trip_id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (location_event_id, trip_id) [pk]
    (trip_id, location_event_id)
  }
}
